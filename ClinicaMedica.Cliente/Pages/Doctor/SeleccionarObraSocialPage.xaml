<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ClinicaMedica.Cliente.Pages.Doctor.SeleccionarObraSocialPage"
    Title="Agregar Obra Social"
    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#121212}">

    <Grid RowDefinitions="*,Auto" Padding="0">

        <!-- Contenido -->
        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="16">

            <Label Text="Seleccioná una Obra Social:"
                   FontSize="18"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

            <Picker x:Name="PickerObras"
                    Title="Obras Sociales disponibles"
                    TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />

            <Button Text="Agregar"
                    Clicked="OnAgregar"
                    HorizontalOptions="Center"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="10" />

        </VerticalStackLayout>

        <!-- Volver fijo abajo -->
        <Button Grid.Row="1"
                Text="Volver"
                Clicked="OnVolver"
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2C}"
                TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                CornerRadius="10"
                Margin="16,0,16,16" />

    </Grid>
</ContentPage>
