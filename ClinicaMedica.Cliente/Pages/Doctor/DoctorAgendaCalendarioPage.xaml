<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ClinicaMedica.Cliente.Pages.Doctor.DoctorAgendaCalendarioPage"
    Title="Agenda">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16">

        <!-- Header Mes -->
        <Grid ColumnDefinitions="Auto,*,Auto" Row="0" Padding="0,0,0,10">
            <Button Text="◀" Clicked="OnPrevMonth" WidthRequest="44" />
            <Label x:Name="MesLabel" Grid.Column="1"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontAttributes="Bold"
                   FontSize="18"/>
            <Button Text="▶" Grid.Column="2" Clicked="OnNextMonth" WidthRequest="44" />
        </Grid>

        <!-- Nombres de días -->
        <Grid Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Padding="0,0,0,8">
            <Label Text="L" HorizontalOptions="Center"/>
            <Label Text="M" Grid.Column="1" HorizontalOptions="Center"/>
            <Label Text="X" Grid.Column="2" HorizontalOptions="Center"/>
            <Label Text="J" Grid.Column="3" HorizontalOptions="Center"/>
            <Label Text="V" Grid.Column="4" HorizontalOptions="Center"/>
            <Label Text="S" Grid.Column="5" HorizontalOptions="Center"/>
            <Label Text="D" Grid.Column="6" HorizontalOptions="Center"/>
        </Grid>

        <!-- Calendario + detalle -->
        <Grid Row="2" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*">

            <ActivityIndicator x:Name="Loading" IsVisible="False" IsRunning="False" />

            <CollectionView x:Name="CalendarGrid"
                            Grid.Row="1"
                            ItemsLayout="VerticalGrid, 7"
                            SelectionMode="Single"
                            SelectionChanged="OnDaySelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="6" Margin="2" CornerRadius="10" BorderColor="#DDD">
                            <Frame.Triggers>
                                <!-- Días fuera del mes -->
                                <DataTrigger TargetType="Frame" Binding="{Binding IsCurrentMonth}" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </DataTrigger>

                                <!-- Día ocupado -->
                                <DataTrigger TargetType="Frame" Binding="{Binding IsOccupied}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#FFE8E8"/>
                                    <Setter Property="BorderColor" Value="#FF6B6B"/>
                                </DataTrigger>

                                <!-- Día seleccionado -->
                                <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#E9EEFC"/>
                                    <Setter Property="BorderColor" Value="#0A68FF"/>
                                </DataTrigger>
                            </Frame.Triggers>

                            <Label Text="{Binding DayText}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"/>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label x:Name="DiaSeleccionadoLabel"
                   Grid.Row="2"
                   Text="Seleccioná un día"
                   FontAttributes="Bold"
                   Margin="0,12,0,6"/>

            <CollectionView x:Name="TurnosList" Grid.Row="2" Margin="0,40,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*" Padding="10" Margin="0,4" BackgroundColor="White">
                            <Label Text="{Binding Hora}" FontAttributes="Bold"/>
                            <Label Grid.Column="1" Text="{Binding Estado}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>
