<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    x:Class="ClinicaMedica.Cliente.Pages.Doctor.GenerarTurnosPage"
    Title="Generar Turnos">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Seleccione una Agenda"
               FontAttributes="Bold"
               FontSize="18"/>

        <Picker x:Name="AgendaPicker"
                Title="Agenda disponible" />

        <Label Text="Seleccione Fecha"
               FontAttributes="Bold"
               FontSize="18"/>

        <DatePicker x:Name="FechaPicker"
                    MinimumDate="{x:Static sys:DateTime.Today}"/>

        <Button Text="Generar Turnos"
                BackgroundColor="#4CAF50"
                TextColor="White"
                CornerRadius="8"
                Clicked="OnGenerarTurnos"/>

    </VerticalStackLayout>

</ContentPage>
