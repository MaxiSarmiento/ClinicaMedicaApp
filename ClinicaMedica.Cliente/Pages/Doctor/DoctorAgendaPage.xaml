<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ClinicaMedica.Cliente.Pages.Doctor.DoctorAgendaPage"
    Title="Configurar Agenda"
    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#121212}">

    <Grid RowDefinitions="*,Auto" Padding="0">

        <!-- Contenido scrolleable -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="14">

                <Label Text="Configurar Agenda"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

                <!-- BOTONES PRINCIPALES -->
                <Button Text="Crear turno singular"
                        Clicked="OnConfigurarSingular"
                        BackgroundColor="#0A68FF"
                        TextColor="White"
                        CornerRadius="10" />

                <Button Text="Generar turnos masivos"
                        Clicked="OnGenerarMasivo"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="10" />

                <Label Text="Agendas semanales"
                       FontSize="18"
                       FontAttributes="Bold"
                       Margin="0,20,0,0"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

                <!-- LISTA DE AGENDAS -->
                <CollectionView x:Name="AgendaList">
                    <CollectionView.EmptyView>
                        <Label Text="No hay reglas semanales cargadas."
                               TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}"
                               HorizontalOptions="Center"
                               Margin="0,20,0,0" />
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10"
                                   Margin="0,5"
                                   CornerRadius="12"
                                   BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2C}">
                                <VerticalStackLayout Spacing="6">

                                    <Label Text="{Binding DiaSemana}"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

                                    <Label Text="{Binding HoraInicio}"
                                           TextColor="{AppThemeBinding Light=#333333, Dark=#DDDDDD}" />

                                    <Label Text="{Binding HoraFin}"
                                           TextColor="{AppThemeBinding Light=#333333, Dark=#DDDDDD}" />

                                    <Label Text="{Binding DuracionMinutos, StringFormat='Duración: {0} min'}"
                                           TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}" />

                                    <Button Text="Eliminar"
                                            BackgroundColor="IndianRed"
                                            TextColor="White"
                                            CommandParameter="{Binding}"
                                            Clicked="OnEliminar"
                                            CornerRadius="10" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Volver fijo abajo -->
        <Button Grid.Row="1"
                Text="Volver"
                Clicked="OnVolver"
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2C}"
                TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                CornerRadius="10"
                Margin="16,0,16,16" />

    </Grid>
</ContentPage>
