<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:ClinicaMedica.Cliente.Converters"
    x:Class="ClinicaMedica.Cliente.Pages.Admin.UsuariosPage"
    Title="Usuarios"
    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <x:Array x:Key="Roles" Type="{x:Type x:String}">
                <x:String>Paciente</x:String>
                <x:String>Doctor</x:String>
                <x:String>Admin</x:String>
            </x:Array>

            <converters:BoolToBloquearTextoConverter x:Key="BoolToBloquearTextoConverter" />
            <converters:RolIndexConverter x:Key="RolIndexConverter" />

            <!--Color del nombre: naranja si bloqueado, sino blanco/negro según tema -->
            <converters:BoolToNombreColorConverter x:Key="BloqueadoNombreColor" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="16" RowDefinitions="*,Auto" RowSpacing="10">

        <CollectionView x:Name="UsuariosList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        Padding="12"
                        Margin="6"
                        CornerRadius="12"
                        HasShadow="True"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                        BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2C}">

                        <VerticalStackLayout Spacing="8">

                            <Label
                                Text="{Binding NombreCompleto}"
                                FontAttributes="Bold"
                                FontSize="16"
                                TextColor="{Binding Bloqueado, Converter={StaticResource BloqueadoNombreColor}}" />

                            <Label
                                Text="{Binding Email}"
                                FontSize="12"
                                TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}" />

                            <Label
                                Text="{Binding Id, StringFormat='ID: {0}'}"
                                FontSize="12"
                                TextColor="{AppThemeBinding Light=#666666, Dark=#BDBDBD}" />

                            <!-- Rol actual + selector -->
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10"
                                  RowSpacing="6">

                                <Label
                                    Text="Rol actual:"
                                    VerticalOptions="Center"
                                    TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding Rol}"
                                    FontAttributes="Bold"
                                    VerticalOptions="Center"
                                    TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

                                <Label
                                    Grid.Row="1"
                                    Text="Cambiar rol:"
                                    VerticalOptions="Center"
                                    TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

                                <Picker
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Title="Seleccionar rol"
                                    ItemsSource="{StaticResource Roles}"
                                    SelectedIndex="{Binding Rol, Mode=TwoWay, Converter={StaticResource RolIndexConverter}}"
                                    WidthRequest="180"
                                    TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
                            </Grid>

                            <Button
                                Text="Guardar rol"
                                Clicked="OnGuardarRol"
                                CommandParameter="{Binding}"
                                BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1976D2}"
                                TextColor="White"
                                CornerRadius="10" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                                <!-- Bloquear / Desbloquear -->
                                <Button
                                    Grid.Column="0"
                                    Text="{Binding Bloqueado, Converter={StaticResource BoolToBloquearTextoConverter}}"
                                    Clicked="OnToggleBloqueo"
                                    CommandParameter="{Binding}"
                                    BackgroundColor="{AppThemeBinding Light=#FFA000, Dark=#FFA000}"
                                    TextColor="White"
                                    CornerRadius="10" />

                                <!-- Eliminar -->
                                <Button
                                    Grid.Column="1"
                                    Text="Eliminar"
                                    Clicked="OnEliminarUsuario"
                                    CommandParameter="{Binding}"
                                    BackgroundColor="{AppThemeBinding Light=#D32F2F, Dark=#D32F2F}"
                                    TextColor="White"
                                    CornerRadius="10" />

                            </Grid>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Grid.Row="1"
            Text="Volver"
            Clicked="OnVolver"
            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2C}"
            TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
            CornerRadius="10" />

    </Grid>
</ContentPage>
