<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ClinicaMedica.Cliente.Pages.Admin.HomeAdminPage"
    Title="Admin">

    <VerticalStackLayout Padding="24" Spacing="12">

        <Label Text="Menu Admin" FontSize="22"/>

        <Button Text="Subir Estudio" Clicked="OnSubirEstudio"/>
        <Button Text="Editar / Eliminar Estudios" Clicked="OnEditarEstudios"/>

        <Button Text="Obras Sociales" Clicked="OnObrasSociales" />
        <Button Text="Gestionar Especialidades" Clicked="OnEspecialidades"/>

       
        <Button Text="Usuarios" Clicked="OnUsuarios"/>
        <Button Text="Cerrar sesión"
         BackgroundColor="#444"
         TextColor="White"
         Clicked="OnLogout"/>
    </VerticalStackLayout>
</ContentPage>
