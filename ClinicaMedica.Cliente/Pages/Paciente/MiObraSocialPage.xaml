<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ClinicaMedica.Cliente.Pages.Paciente.MiObraSocialPage"
    Title="Mi Obra Social">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label Text="Mi Obra Social"
               FontSize="22"
               HorizontalOptions="Center" />

        <Label x:Name="LblOS"
               FontSize="18"
               HorizontalOptions="Center" />

        <Label Text="Número de Socio:"
               FontSize="18" />

        <Entry x:Name="EntryNroSocio"
               Placeholder="Ingrese su número de socio" />

        <Button Text="Guardar"
                Clicked="OnGuardar"
                BackgroundColor="#4CAF50"
                TextColor="White" />

        <Button Text="Cambiar Obra Social"
                Clicked="OnCambiar"
                BackgroundColor="#2196F3"
                TextColor="White" />

    </VerticalStackLayout>

</ContentPage>
