<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ClinicaMedica.Cliente.Pages.Paciente.EditarPerfilPacientePage"
    Title="Editar Perfil"
    BackgroundColor="{AppThemeBinding Light=#F7F7F7, Dark=#121212}">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- HEADER FIJO -->
        <Grid Padding="16"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
              ColumnDefinitions="Auto,*">

            <Button Text="← Volver"
                    Clicked="OnVolver"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#0A68FF, Dark=#7FB0FF}"
                    FontAttributes="Bold"/>

            <Label Grid.Column="1"
                   Text="Editar Perfil"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
        </Grid>

        <!-- CONTENIDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="14">

                <ActivityIndicator x:Name="Loading"
                                   IsVisible="False"
                                   IsRunning="False"
                                   Color="{AppThemeBinding Light=#0A68FF, Dark=#7FB0FF}"/>

                <!-- Nombre -->
                <Label Text="Nombre"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                <Entry x:Name="TxtNombre"
                       Placeholder="Nombre"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                       PlaceholderColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>

                <!-- Apellido -->
                <Label Text="Apellido"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                <Entry x:Name="TxtApellido"
                       Placeholder="Apellido"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                       PlaceholderColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>

                <!-- DNI -->
                <Label Text="DNI"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                <Entry x:Name="TxtDni"
                       IsEnabled="False"
                       Keyboard="Numeric"
                       TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}"
                       PlaceholderColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                       BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#232323}"/>

                <!-- Email -->
                <Label Text="Email"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                <Entry x:Name="TxtEmail"
                       IsEnabled="False"
                       Keyboard="Email"
                       TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}"
                       PlaceholderColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                       BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#232323}"/>

                <!-- Fecha Nacimiento + Edad -->
                <Label Text="Fecha de nacimiento"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <DatePicker x:Name="FechaNacimientoPicker"
                                DateSelected="OnFechaNacimientoChanged"
                                TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>
                    <Label x:Name="EdadLabel"
                           Text="(— años)"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#555555, Dark=#BBBBBB}"/>
                </HorizontalStackLayout>

                <!-- Obra Social -->
                <Label Text="Obra Social"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                <Label x:Name="LblObraSocial"
                       Text="Sin Obra Social"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#222222, Dark=#FFFFFF}"/>

                <Button Text="Cambiar Obra Social"
                        Clicked="OnCambiarOS"
                        BackgroundColor="{AppThemeBinding Light=#E9EEFC, Dark=#27324A}"
                        TextColor="{AppThemeBinding Light=#0A68FF, Dark=#7FB0FF}"
                        CornerRadius="10"/>

                <!-- Nº Socio -->
                <Label Text="Número de socio"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                <Entry x:Name="TxtNroSocio"
                       Placeholder="N° de socio"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                       PlaceholderColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>

                <!-- Guardar -->
                <Button Text="Guardar Cambios"
                        BackgroundColor="{AppThemeBinding Light=#0A68FF, Dark=#2F7DFF}"
                        TextColor="White"
                        HeightRequest="50"
                        CornerRadius="10"
                        FontAttributes="Bold"
                        Clicked="OnGuardar"/>

                <!-- CAMBIAR CONTRASEÑA -->
                <Frame Padding="12"
                       CornerRadius="12"
                       BorderColor="{AppThemeBinding Light=#DDDDDD, Dark=#333333}"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="Cambiar contraseña"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>

                        <Label Text="Contraseña actual"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#BBBBBB}"/>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry x:Name="PasswordActualEntry"
                                   Grid.Column="0"
                                   Placeholder="Contraseña actual"
                                   IsPassword="True"
                                   TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>
                            <Button Grid.Column="1"
                                    Text="👁"
                                    Clicked="OnTogglePasswordActual"
                                    BackgroundColor="Transparent"
                                    Padding="0"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    FontSize="18"
                                    TextColor="{AppThemeBinding Light=#0A68FF, Dark=#7FB0FF}" />
                        </Grid>

                        <Label Text="Nueva contraseña"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#BBBBBB}"/>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry x:Name="PasswordNuevaEntry"
                                   Grid.Column="0"
                                   Placeholder="Nueva contraseña"
                                   IsPassword="True"
                                   TextChanged="OnPasswordFieldsChanged"
                                   TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>
                            <Button Grid.Column="1"
                                    Text="👁"
                                    Clicked="OnTogglePasswordNueva"
                                    BackgroundColor="Transparent"
                                    Padding="0"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    FontSize="18"
                                    TextColor="{AppThemeBinding Light=#0A68FF, Dark=#7FB0FF}" />
                        </Grid>

                        <Label Text="Repetir nueva contraseña"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#BBBBBB}"/>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry x:Name="PasswordRepetirEntry"
                                   Grid.Column="0"
                                   Placeholder="Repetir nueva contraseña"
                                   IsPassword="True"
                                   TextChanged="OnPasswordFieldsChanged"
                                   TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#777777, Dark=#AAAAAA}"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>
                            <Button Grid.Column="1"
                                    Text="👁"
                                    Clicked="OnTogglePasswordRepetir"
                                    BackgroundColor="Transparent"
                                    Padding="0"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    FontSize="18"
                                    TextColor="{AppThemeBinding Light=#0A68FF, Dark=#7FB0FF}" />
                        </Grid>

                        <Label x:Name="LblPasswordError"
                               IsVisible="False"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#D32F2F, Dark=#FF6B6B}" />

                        <Button Text="Actualizar contraseña"
                                Clicked="OnCambiarPassword"
                                BackgroundColor="{AppThemeBinding Light=#444444, Dark=#2A2A2A}"
                                TextColor="White"
                                CornerRadius="10"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>