<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ClinicaMedica.Cliente.Pages.Paciente.BuscarTurnoPacientePage"
    Title="Seleccionar Doctor">

    <CollectionView x:Name="ListaDocs" Margin="16">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Padding="10" Margin="6" BorderColor="Gray">

                    <VerticalStackLayout>
                        <Label Text="{Binding NombreCompleto}" FontAttributes="Bold"/>
                        <Label Text="{Binding Advertencia}" TextColor="Red"/>

                        <Button Text="Ver turnos"
                                CommandParameter="{Binding Id}"
                                Clicked="OnVerTurnos"/>
                    </VerticalStackLayout>

                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
