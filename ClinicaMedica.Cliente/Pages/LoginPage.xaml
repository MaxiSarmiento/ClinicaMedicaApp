<?xml version="1.0" encoding="utf-8" ?>
    
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ClinicaMedica.Cliente.Pages.LoginPage"

    BackgroundColor="White">
    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" IsEnabled="False" />
    </Shell.BackButtonBehavior>
    <ScrollView>
        
        <VerticalStackLayout Padding="30" Spacing="20">

            <Image Source="logo_clinica.png"
                   HeightRequest="240"
                   HorizontalOptions="Center" />

            
            <Label Text="¡Bienvenido!"
                   FontSize="22"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="Black"
                   Margin="0,10,0,0"/>

            <Label Text="E-mail"
            FontSize="18"
            FontAttributes="Bold"
            TextColor="Black"
            Margin="5,10,0,-15"/>
            <Frame CornerRadius="10"
                   Padding="10"
                   BorderColor="#BFBFBF"
                   BackgroundColor="White">
                
                <Entry x:Name="EmailEntry"
                       TextColor="Black"
                       Placeholder="Email"
                       FontSize="16"/>
            </Frame>
            <Label Text="Contraseña"
            FontSize="18"
            FontAttributes="Bold"
            TextColor="Black"
            Margin="5,10,0,-15"/>
            <Frame CornerRadius="10"
                   Padding="10"
                   BorderColor="#BFBFBF"
                   BackgroundColor="White">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Contraseña"
                       TextColor="DarkGrey"
                       IsPassword="True"
                       FontSize="16"/>
            </Frame>

            <Button Text="Iniciar Sesión"
                    Clicked="OnLoginClicked"
                    BackgroundColor="#0A68FF"
                    TextColor="White"
                    FontSize="18"
                    CornerRadius="10"
                    HeightRequest="50"/>

            <Button Text="Crear Usuario"
                    Clicked="OnCrearUsuarioClicked"
                    BackgroundColor="Transparent"
                    TextColor="#0A68FF"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
